<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141210"
    android:orientation="vertical">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000000"
        app:use_controller="true"
        app:resize_mode="fit"/>
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#141210"
            app:elevation="0dp">



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_scrollFlags="scroll|snap"
                    android:background="#141210"
                    android:paddingBottom="16dp"
                    >

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="#1AD4AF37"
                        android:paddingHorizontal="16dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@android:drawable/toast_frame"
                                android:backgroundTint="#D4AF37"
                                android:text="Đăng Ký Ngay"
                                android:textColor="#141210"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="2dp"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="đ XXX/Năm"
                                android:textColor="#D4AF37"
                                android:textStyle="bold"
                                android:textSize="14sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_vip"
                                app:tint="#D4AF37"
                                android:layout_marginEnd="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ưu Đãi Có Hạn"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="16dp">
                        <TextView
                            android:id="@+id/tv_movie_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mùa Hè Nồng Nhiệt"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="9.9"
                                android:textColor="#D4AF37"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:layout_marginEnd="12dp"
                                android:drawableStart="@drawable/ic_star"
                                android:drawableTint="#D4AF37"
                                android:drawablePadding="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2026"
                                android:textColor="#7C766B"
                                android:background="#252830"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="1dp"
                                android:textSize="11sp"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="T13"
                                android:textColor="#7C766B"
                                android:background="#252830"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="1dp"
                                android:textSize="11sp"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phụ đề"
                                android:textColor="#7C766B"
                                android:background="#252830"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="1dp"
                                android:textSize="11sp"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trung Quốc đại lục · Lãng Mạn"
                                android:textColor="#B5AFA5"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp">
                            <TextView
                                android:id="@+id/tv_movie_desc"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mùa Hè Nồng Nhiệt là bộ phim truyền hình tình cảm do Bao Thượng Ân (diễn trong Thủy Long Ngâm), Châu Kha Vũ đóng chính..."
                                android:textColor="#7C766B"
                                android:textSize="13sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:layout_toStartOf="@id/btn_expand_desc"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:id="@+id/btn_expand_desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_alignBottom="@id/tv_movie_desc"
                                android:text="Xem thêm"
                                android:textColor="#E5E0D8"
                                android:textStyle="bold"
                                android:textSize="13sp"/>
                        </RelativeLayout>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_movie_actors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/stat_sys_download"
                            app:tint="#E5E0D8"
                            android:layout_marginEnd="28dp"/>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_input_add"
                            app:tint="#E5E0D8"
                            android:layout_marginEnd="28dp"/>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_share"
                            app:tint="#E5E0D8"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#252830"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="#141210"
                android:paddingHorizontal="16dp"
                app:layout_scrollFlags="enterAlways">

                <LinearLayout
                    android:id="@+id/tab_episodes"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="24dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tv_tab_episodes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch cập nhật"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp"/>
                    <View
                        android:id="@+id/indicator_episodes"
                        android:layout_width="30dp"
                        android:layout_height="2dp"
                        android:background="#D4AF37"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tab_recommendations"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tv_tab_recommendations"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đề xuất cho bạn"
                        android:textColor="#7C766B"
                        android:textSize="15sp"/>
                    <View
                        android:id="@+id/indicator_recommendations"
                        android:layout_width="30dp"
                        android:layout_height="2dp"
                        android:background="#00000000"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="60dp">

                <LinearLayout
                    android:id="@+id/layout_section_episodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="8dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@+id/tv_btn_all_episodes">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cập nhật tới tập 7 / tổng cộng 29 tập"
                                android:textColor="#7C766B"
                                android:textSize="12sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thành viên VIP: Bắt đầu từ 06-19 giờ, Mỗi ngày 11:00 giờ cập nhật 1 tập."
                                android:textColor="#5A554E"
                                android:layout_marginTop="2dp"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tv_btn_all_episodes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Khác >"
                            android:textColor="#7C766B"
                            android:textSize="12sp" />
                    </RelativeLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_episodes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_section_recommendations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đề xuất cho bạn"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_detail_recommendations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>