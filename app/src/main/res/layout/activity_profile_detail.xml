<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <RelativeLayout
        android:id="@+id/toolbar_profile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_profile_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/btn_profile_back"
            android:layout_centerVertical="true"
            android:text="Thông tin cá nhân"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/pb_profile_detail_loading"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:indeterminateTint="#D4AF37"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scroll_profile_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/toolbar_profile"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <FrameLayout
                android:id="@+id/layout_avatar_click"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:clickable="false"
                android:focusable="false"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="#161618"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/img_detail_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_nav_account" />
                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/img_camera_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:background="#222224"
                    android:padding="5dp"
                    android:src="@drawable/ic_camera"

                    android:visibility="gone"
                    tools:visibility="visible" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_detail_fullname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Trieu Truong" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_profile"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:text="Chỉnh sửa hồ sơ"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#222224"
                android:paddingHorizontal="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#222224"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nav_account" app:tint="#D4AF37" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Họ và tên" android:textColor="#888888" android:textSize="13sp"/>
                        <EditText android:id="@+id/edt_detail_fullname" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:textColor="#E5E5E5" android:textSize="15sp" android:background="@android:color/transparent" android:enabled="false" android:inputType="textPersonName" tools:text="Trieu Truong"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#222224"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nav_account" app:tint="#D4AF37" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên tài khoản" android:textColor="#888888" android:textSize="13sp"/>
                        <EditText android:id="@+id/tv_detail_username" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:textColor="#E5E5E5" android:textSize="15sp" android:textStyle="bold" android:background="@android:color/transparent" android:enabled="false" android:inputType="text" tools:text="trieu123"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#222224"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_comment" app:tint="#D4AF37" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email" android:textColor="#888888" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_detail_email" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:textColor="#E5E5E5" android:textSize="15sp" tools:text="trieu@gmail.com"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#222224"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_support" app:tint="#D4AF37" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại" android:textColor="#888888" android:textSize="13sp"/>
                        <EditText android:id="@+id/tv_detail_phone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:textColor="#E5E5E5" android:textSize="15sp" android:background="@android:color/transparent" android:enabled="false" android:inputType="phone" tools:text="0912345678"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#222224"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_transaction" app:tint="#D4AF37" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày sinh" android:textColor="#888888" android:textSize="13sp"/>
                        <EditText android:id="@+id/tv_detail_dob" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:textColor="#E5E5E5" android:textSize="15sp" android:background="@android:color/transparent" android:focusable="false" android:clickable="true" android:inputType="none" android:cursorVisible="false" tools:text="23-03-2000"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#222224"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_google" app:tint="#D4AF37" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Google" android:textColor="#888888" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_detail_google_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:textColor="#D4AF37" android:textSize="15sp" android:textStyle="bold" tools:text="Đã liên kết"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#222224"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>